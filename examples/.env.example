# Copy this file to `.env` (in the same directory) and fill in your keys.
# `.env` is gitignored — it will not be committed.

# --- AEVS (required by all three examples) -----------------------------------
# Get them at https://aevs.fetch.ai (sign in -> create API key, create agent).
AEVS_API_KEY=aevs_sk_<key_id>_<hex_secret>
AEVS_AGENT_ID=<your-agent-uuid>
# Optional: "public", "private" (default), or "proof_only" (strips inputs/outputs from receipts)
# AEVS_RECEIPT_VISIBILITY=private

# --- OpenAI (only example 02) ------------------------------------------------
OPENAI_API_KEY=sk-...

# --- ASI:One (examples 03 and 04) -------------------------------------------
# Get one at https://asi1.ai
ASI_API_KEY=sk_...
